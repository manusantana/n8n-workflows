        "jsCode": "const fechaDigest = new Date().toLocaleDateString('en-CA', { timeZone: 'Europe/Madrid' });\n// devuelve YYYY-MM-DD en horario Madrid\n\nfunction pickGeminiText(j) {\n  if (typeof j.content === 'string' && j.content.trim()) return j.content.trim();\n  const a = j.content?.parts?.[0]?.text;\n  if (typeof a === 'string' && a.trim()) return a.trim();\n  const b = j.content?.parts?.parts?.[0]?.text;\n  if (typeof b === 'string' && b.trim()) return b.trim();\n  return null;\n}\n\nfunction buildTitle(originalTitle, summaryText) {\n  if (originalTitle && String(originalTitle).trim()) return String(originalTitle).trim();\n  if (!summaryText) return 'Señales estratégicas para crecer en B2B en 2026';\n\n  const firstSentence = String(summaryText).replace(/\\s+/g, ' ').trim().split(/[.!?]/)[0].trim();\n  const clean = firstSentence.replace(/^[\"'“”]+|[\"'“”]+$/g, '');\n  return clean.length > 90 ? `${clean.slice(0, 87).trim()}...` : (clean || 'Señales estratégicas para crecer en B2B en 2026');\n}\n\nreturn $input.all().map((item, idx) => {\n  const j = item.json;\n  const geminiText = pickGeminiText(j);\n  const isAIItem = !!geminiText && (!j.source || !j.original_url || !j.original_title);\n\n  const summaryFinal = geminiText ?? j.original_summary ?? null;\n  const titleFinal = buildTitle(j.original_title, summaryFinal);\n\n  return {\n    json: {\n      source: isAIItem ? 'IA' : (j.source ?? 'rss'),\n      source_type: isAIItem ? 'Gemini' : (j.source_type ?? 'rss'),\n      original_url: isAIItem ? 'https://manusantana.com' : (j.original_url ?? null),\n      original_title: titleFinal,\n      original_summary: summaryFinal,\n      tipo_contenido: j.tipo_contenido ?? null,\n      prioridad: j.prioridad ?? null,\n      potencial_linkedin: j.potencial_linkedin ?? null,\n      potencial_seo: j.potencial_seo ?? null,\n      potencial_nexprix: j.potencial_nexprix ?? null,\n      riesgo_reputacional: j.riesgo_reputacional ?? null,\n      angulo_recomendado: j.angulo_recomendado ?? null,\n      estado: j.estado ?? 'discovered',\n      fecha_digest: fechaDigest,\n      rank_dia: idx + 1,\n    },\n  };\n});\n"
      },
