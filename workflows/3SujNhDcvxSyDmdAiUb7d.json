      "parameters": {
        "jsCode": "function escapeMarkdownV2(value = \"\") {\n  return String(value).replace(/[_*[\\]()~`>#+\\-=|{}.!]/g, \"\\\\$&\");\n}\n\n// Soporta 3 casos: data[], rows[] o items directos\nlet items = [];\nif (Array.isArray($json.data)) items = $json.data;\nelse if (Array.isArray($json.rows)) items = $json.rows;\nelse items = $input.all().map(i => i.json);\n\nitems = items.slice(0, 5);\n\nconst lines = [\"🧠 *Top 5 oportunidades estratégicas de hoy:*\", \"\"];\n\nitems.forEach((item, i) => {\n  const rank = item.rank_dia || i + 1;\n  const title = escapeMarkdownV2(item.original_title || \"Contenido estratégico propio\");\n  const summary = escapeMarkdownV2(item.original_summary || \"\");\n  const url = item.original_url ? escapeMarkdownV2(item.original_url) : \"\";\n\n  const li = escapeMarkdownV2(item.potencial_linkedin ?? \"N/D\");\n  const seo = escapeMarkdownV2(item.potencial_seo ?? \"N/D\");\n  const nx = escapeMarkdownV2(item.potencial_nexprix ?? \"N/D\");\n  const risk = escapeMarkdownV2(item.riesgo_reputacional ?? \"N/D\");\n\n  lines.push(`${rank}️⃣ *${title}*`);\n  if (summary) lines.push(summary);\n  lines.push(`📊 LI ${li} • SEO ${seo} • NExprix ${nx}`);\n  lines.push(`⚠️ Riesgo reputacional: ${risk}`);\n  if (url) lines.push(`🔗 ${url}`);\n  lines.push(\"\");\n});\n\nlines.push(\"👉 Responde con un número \\\\(1\\\\-5\\\\)\");\n\nreturn [{ json: { telegram_message: lines.join(\"\\n\") } }];\n"
      },
