      "position": [
        -416,
        288
      ]
    },
    {
      "parameters": {
        "jsCode": "const html = $json.data || '';\nconst linkId = $('Webhook').item.json.body.link_id;\nconst supabaseUrl = $('Webhook').item.json.body.supabase_url;\nconst supabaseKey = $('Webhook').item.json.body.supabase_key;\n\n// Patterns sorted by specificity\nconst patterns = [\n    /class=\"a-price-whole\">([^<]+)<[/]span>/, // Standard Amazon\n    /class=\"a-offscreen\">([^<]+)<[/]span>/,   // Hidden (accessibility)\n    /id=\"priceblock_ourprice\"[^>]*>([^<]+)</, // Classic 1\n    /id=\"priceblock_dealprice\"[^>]*>([^<]+)</, // Classic 2\n    /class=\"a-color-price\">([^<]+)</,         // Fallback color\n    /\"display_amount\":\"([^\"]+)\"/,             // JSON data-attributes\n];\n\nlet finalPrice = null;\n\nfor (const pattern of patterns) {\n    const match = html.match(pattern);\n    if (match && match[1]) {\n        let text = match[1].trim();\n        text = text.replace(/[^\\d.,]/g, '');\n        if (text.includes(',')) {\n            text = text.replace(/\\./g, '').replace(',', '.');\n        } else if (text.split('.').length > 2) {\n             text = text.replace(/\\./g, '');\n        }\n        const p = parseFloat(text);\n        if (!isNaN(p) && p > 0) {\n            finalPrice = p;\n            break;\n        }\n    }\n}\n\nreturn {\n  price: finalPrice,\n  link_id: linkId,\n  supabase_url: supabaseUrl,\n  supabase_key: supabaseKey,\n  scraped_at: new Date().toISOString()\n};\n"
      },
      "id": "c241b87a-2084-4911-a9db-aa97e9fe7790",
