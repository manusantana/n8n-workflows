        "url": "=https://api.scrapingant.com/v2/general?url={{ $json.body.url }}&x-api-key=1ca62ed142e8431f82d8f6682fb261eb&browser=true&proxy_type=residential&proxy_country=ES&js_snippet=ZG9jdW1lbnQucXVlcnlTZWxlY3RvcigiI3NwLWNjLWFjY2VwdCIpICYmIGRvY3VtZW50LnF1ZXJ5U2VsZWN0b3IoIiNzcC1jYy1hY2NlcHQiKS5jbGljaygp&wait_for_selector=.a-price-whole",
        "options": {}
